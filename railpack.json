{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": [
        {
          "src": "package.json",
          "dest": "package.json"
        },
        {
          "src": "pnpm-lock.yaml",
          "dest": "pnpm-lock.yaml"
        },
        {
          "src": "pnpm-workspace.yaml",
          "dest": "pnpm-workspace.yaml"
        },
        {
          "src": "api/package.json",
          "dest": "api/package.json"
        },
        {
          "src": "cli/package.json",
          "dest": "cli/package.json"
        },
        {
          "src": "web/package.json",
          "dest": "web/package.json"
        },
        "pnpm install --frozen-lockfile --filter api --filter web"
      ]
    },
    "build": {
      "inputs": [
        {
          "step": "install"
        }
      ],
      "commands": [
        { "src": "web", "dest": "web" },
        "pnpm --filter web build",
        "mkdir -p api/static && cp -r web/dist/. api/static/",
        { "src": "tsconfig.base.json", "dest": "tsconfig.base.json" },
        { "src": "api/tsconfig.json", "dest": "api/tsconfig.json" },
        { "src": "api/tsconfig.build.json", "dest": "api/tsconfig.build.json" },
        { "src": "api/src", "dest": "api/src" },
        "pnpm --filter api build"
      ]
    }
  },
  "deploy": {
    "startCommand": "pnpm --filter api start:prod"
  }
}
