{
  "name": "@paulelian-tabarant/ripe",
  "version": "0.2.0",
  "type": "module",
  "bin": {
    "ripe": "./dist/index.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "biome ci ./src ./tests",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "ci:checks": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "init": "node dist/index.js init"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/node": "^22.0.0",
    "nock": "^14.0.0",
    "vitest": "^3.0.0"
  }
}
